{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PostInstall Healthcheck Report Schema",
  "type": "object",
  "required": ["metadata","summary","details"],
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "generated_at": {"type": "string"},
        "inventory_hostname": {"type": "string"},
        "product_name": {"type": "string"},
        "product_version": {"type":"string"}
      }
    },
    "summary": {
      "type": "object",
      "description": "High-level counts and status indicators (added/removed/changed)."
    },
    "details": {
      "type": "object",
      "properties": {
        "hardware": {"type": "object"},
        "os": {"type": "object"},
        "network": {"type": "object"},
        "security": {"type": "object"},
        "packages": {"type": "object"},
        "updates": {"type": "object"},
        "services": {"type": "object"},
        "listening_ports": {"type": "object"},
        "users_groups": {"type": "object"},
        "sudoers": {"type": "string"},
        "features": {"type": "object"},
        "errors": {"type": "object"},
        "raw": {"type": "object", "description": "Raw command outputs for debugging"}
      }
    }
  }
}
